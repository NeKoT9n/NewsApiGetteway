{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "CorsPolicy": "ReactPolicy",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "user-route": {
        "ClusterId": "identity-cluster",
        "CorsPolicy": "ReactPolicy",
        "Match": { "Path": "/api/user/{**catch-all}" }
      },
      "news-route": {
        "ClusterId": "news-cluster",
        "CorsPolicy": "ReactPolicy",
        "Match": { "Path": "/api/news/{**catch-all}" }
      },
      "comments-route": {
        "ClusterId": "news-cluster",
        "CorsPolicy": "ReactPolicy",
        "Match": { "Path": "/api/Comments/{**catch-all}" }
      },
      "aggregation-route": {
        "ClusterId": "aggregation-cluster",
        "CorsPolicy": "ReactPolicy",
        "Match": { "Path": "/api/aggregation/{**catch-all}" }
      },
      "source-route": {
        "ClusterId": "aggregation-cluster",
        "CorsPolicy": "ReactPolicy",
        "Match": { "Path": "/api/source/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://identity-service:8080" }
        }
      },
      "news-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://news-api:8080" }
        }
      },
      "aggregation-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://news-aggregator:8080" }
        }
      }
    }
  }
}